---
// src/components/ClosingSection.astro
import Sparkle from './Sparkle.astro';
---

<section id="closing" class="section js-section" data-bg="navy" style="min-height: 80vh; justify-content: center; align-items: center; text-align: center;">
  <div class="section-content js-fade-up opacity-0" style="display: flex; flex-direction: column; align-items: center;">
    <div style="margin-bottom: 2rem;">
      <Sparkle color="var(--color-coral)" size={32} className="floating-element" />
    </div>
    
    <h2 class="title-display color-yellow" style="font-size: clamp(3rem, 8vw, 4.5rem); margin-bottom: 0.5rem;">Happy Birthday,</h2>
    <h2 class="title-display color-white" style="font-size: clamp(4rem, 12vw, 6rem); margin-bottom: 2rem;">Zura! 🤍</h2>
    
    <div style="margin-top: 4rem;">
      <h3 class="title-heading text-gradient-shimmer" style="font-size: clamp(2rem, 6vw, 3rem);">I love you.</h3>
      <p class="text-script color-white opacity-80" style="margin-top: 1rem; font-size: clamp(1.5rem, 5vw, 2.5rem);">Forever and always.</p>
    </div>
  </div>
</section>
