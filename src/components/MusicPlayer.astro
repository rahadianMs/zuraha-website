---
// src/components/MusicPlayer.astro
// The audio element. JS logic handled centrally in index.astro.
interface Props {
  audioSrc: string;
}

const { audioSrc } = Astro.props;
---

<div class="music-player-container" style="display:none; position:fixed; z-index:-1;">
  <audio id="bgMusic" preload="auto">
    <source src={audioSrc} type="audio/mp4">
    <source src={audioSrc} type="audio/mpeg">
    Your browser does not support the audio element.
  </audio>
</div>
