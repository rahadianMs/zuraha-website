---
// src/components/SplashScreen.astro
// Script logic is handled centrally in index.astro to avoid race conditions.
import Sparkle from './Sparkle.astro';
import Squiggle from './Squiggle.astro';
---

<style>
  @keyframes float-a {
    0%, 100% { transform: translateY(0) rotate(-5deg); }
    50%       { transform: translateY(-12px) rotate(-2deg); }
  }
  @keyframes float-b {
    0%, 100% { transform: translateY(0) rotate(8deg); }
    50%       { transform: translateY(-16px) rotate(5deg); }
  }
  @keyframes float-c {
    0%, 100% { transform: translateY(0) scale(1); }
    50%       { transform: translateY(-8px) scale(1.08); }
  }
  @keyframes twinkle {
    0%, 100% { opacity: 0.4; transform: scale(0.9); }
    50%       { opacity: 1;   transform: scale(1.1); }
  }
  @keyframes pulse-ring {
    0%   { box-shadow: 0 0 0 0   rgba(245, 200, 66, 0.3); }
    70%  { box-shadow: 0 0 0 18px rgba(245, 200, 66, 0); }
    100% { box-shadow: 0 0 0 0   rgba(245, 200, 66, 0); }
  }

  .splash-deco {
    position: absolute;
    pointer-events: none;
    z-index: 0;
  }

  /* Top cluster */
  .deco-sparkle-1 {
    top: 12%;
    left: 50%;
    transform: translateX(-50%);
    animation: float-c 4s ease-in-out infinite;
  }
  .deco-sparkle-2 {
    top: 16%;
    left: calc(50% - 80px);
    animation: twinkle 3s ease-in-out infinite;
  }
  .deco-sparkle-3 {
    top: 10%;
    left: calc(50% + 60px);
    animation: twinkle 3.5s ease-in-out infinite 0.5s;
  }

  /* Side ornaments (hidden on very small screens) */
  .deco-left-1 {
    top: 30%;
    left: 5%;
    animation: float-a 5s ease-in-out infinite;
    opacity: 0.65;
  }
  .deco-left-2 {
    bottom: 25%;
    left: 8%;
    animation: float-b 6s ease-in-out infinite 1s;
    opacity: 0.5;
  }
  .deco-right-1 {
    top: 35%;
    right: 5%;
    animation: float-b 5.5s ease-in-out infinite 0.3s;
    opacity: 0.65;
  }
  .deco-right-2 {
    bottom: 20%;
    right: 8%;
    animation: float-a 4.5s ease-in-out infinite 0.8s;
    opacity: 0.5;
  }

  /* Squiggle above button */
  .deco-squiggle {
    bottom: calc(50% - 80px);
    left: 50%;
    transform: translateX(calc(-50% - 20px)) rotate(-10deg);
    opacity: 0.5;
    animation: float-c 4s ease-in-out infinite 0.4s;
  }

  /* Hide side ornaments on tiny phones */
  @media (max-width: 400px) {
    .deco-left-1, .deco-left-2, .deco-right-1, .deco-right-2 { display: none; }
  }

  .splash-label {
    font-family: 'Patrick Hand', 'Comic Sans MS', cursive;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    font-size: clamp(0.7rem, 2vw, 0.9rem);
    opacity: 0.75;
  }

  .splash-title {
    font-family: 'Patrick Hand', 'Comic Sans MS', cursive;
    font-size: clamp(4.5rem, 18vw, 8rem);
    color: var(--color-yellow);
    line-height: 1;
    margin: 0;
    text-shadow: 0 4px 24px rgba(245, 200, 66, 0.35);
  }

  .splash-subtitle {
    font-family: 'Patrick Hand', 'Comic Sans MS', cursive;
    font-size: clamp(1rem, 3.5vw, 1.4rem);
    line-height: 1.7;
    opacity: 0.82;
    max-width: 380px;
  }

  .btn-start-inner {
    font-family: 'Patrick Hand', 'Comic Sans MS', cursive;
    font-size: clamp(1rem, 3vw, 1.25rem);
    letter-spacing: 0.06em;
  }

  .btn-hint {
    font-family: 'Patrick Hand', 'Comic Sans MS', cursive;
    font-size: clamp(0.75rem, 2vw, 0.85rem);
    opacity: 0.65;
    font-weight: 400;
  }

  /* Override btn-start font and add pulse ring */
  #btnStart {
    font-family: 'Patrick Hand', 'Comic Sans MS', cursive !important;
    animation: pulse-slow 2.5s ease-in-out infinite, pulse-ring 2.5s ease-in-out infinite;
  }
</style>

<div id="splashScreen" class="splash-bg">

  <!-- Decorative top sparkle cluster -->
  <div class="splash-deco deco-sparkle-1">
    <Sparkle color="var(--color-yellow)" size={48} />
  </div>
  <div class="splash-deco deco-sparkle-2">
    <Sparkle color="var(--color-white)" size={22} />
  </div>
  <div class="splash-deco deco-sparkle-3">
    <Sparkle color="var(--color-coral-light)" size={18} />
  </div>

  <!-- Side sparkles -->
  <div class="splash-deco deco-left-1">
    <Sparkle color="var(--color-yellow)" size={36} />
  </div>
  <div class="splash-deco deco-left-2">
    <Sparkle color="var(--color-coral-light)" size={24} />
  </div>
  <div class="splash-deco deco-right-1">
    <Sparkle color="var(--color-coral-light)" size={30} />
  </div>
  <div class="splash-deco deco-right-2">
    <Sparkle color="var(--color-yellow)" size={20} />
  </div>

  <!-- Squiggle near button -->
  <div class="splash-deco deco-squiggle">
    <Squiggle color="var(--color-coral)" />
  </div>

  <!-- Main content -->
  <div class="splash-content" style="padding: 0 1.5rem; max-width: 520px; position: relative; z-index: 1; width: 100%;">
    <p class="splash-label color-coral-light">Sebuah persembahan untuk</p>

    <h1 class="splash-title">Zura</h1>

    <p class="splash-subtitle color-white" style="text-align: center;">
      Ada banyak hal yang terlewat jika kita tidak pernah berhenti sejenak untuk mengingat.
    </p>

    <button
      id="btnStart"
      class="btn-start pulse-slow"
      style="display: flex; flex-direction: column; align-items: center; gap: 0.4rem; justify-content: center; width: 100%; max-width: 300px; margin: 0 auto; padding: 1.25rem 2rem;"
    >
      <span class="btn-start-inner">Buka Kenangan ✨</span>
      <span class="btn-hint">(Pasang headset &amp; nikmati)</span>
    </button>
  </div>
</div>
